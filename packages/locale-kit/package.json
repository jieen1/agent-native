{
  "name": "locale-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Runtime i18n foundation (t/tx, locale store, provider, sync) for Agent-Native templates. TS source is compiled by the consuming app's Vite/esbuild — no build step.",
  "exports": {
    ".": "./src/index.ts",
    "./format": "./src/format.ts",
    "./action": "./src/action.ts",
    "./server": "./src/server.ts",
    "./cli": "./src/cli/index.ts",
    "./vite": {
      "types": "./src/vite/index.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "i18n:extract": "tsx src/cli/index.ts extract",
    "i18n:audit": "tsx src/cli/index.ts audit --missing --unwrapped",
    "i18n:audit:missing": "tsx src/cli/index.ts audit --missing",
    "i18n:audit:unwrapped": "tsx src/cli/index.ts audit --unwrapped"
  },
  "peerDependencies": {
    "react": "*",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@agent-native/core": "workspace:*",
    "@tanstack/react-query": "^5.99.2",
    "@types/node": "^24.2.1",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "zod": "^4.4.3"
  }
}
